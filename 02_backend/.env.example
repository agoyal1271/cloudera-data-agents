# ==========================================
# Cloudera AI Agents - Configuration
# ==========================================
# Copy this file to .env and fill in your values
# Priority: Database (runtime overrides) > Environment Variables > Defaults

# ── LLM Provider Configuration ────────────────────────────────────
# Which LLM backend to use: ollama, openai, anthropic, azure_openai
LLM_PROVIDER=ollama

# Model to use (depends on selected provider)
LLM_MODEL=nomic-embed-text

# ── Ollama (Local LLM) ───────────────────────────────────────────
# URL to local Ollama instance
OLLAMA_URL=http://localhost:11434

# ── OpenAI ──────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Anthropic (Claude) ──────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Azure OpenAI ────────────────────────────────────────────────
# Get from Azure Portal
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com/
# Deployment name in Azure (default: text-embedding-ada-002)
AZURE_OPENAI_DEPLOYMENT=text-embedding-ada-002

# ── Knox Gateway (Secure JDBC/REST access to Hive/Impala) ────────
# Hostname of Knox Gateway
KNOX_HOST=

# Knox username (default: admin)
KNOX_USER=admin

# Knox password
KNOX_PASSWORD=

# ── Kafka Schema Registry ───────────────────────────────────────
# URL to Schema Registry for Kafka topic schemas
SCHEMA_REGISTRY_URL=

# ── Qdrant Vector Database ──────────────────────────────────────
# URL to Qdrant instance (for semantic search, vector storage)
# Default: http://localhost:6333
QDRANT_URL=http://localhost:6333

# Qdrant API key (if using managed Qdrant Cloud)
QDRANT_API_KEY=

# ── Catalog Embedding Model ─────────────────────────────────────
# Model to use for semantic catalog embeddings (must match LLM_PROVIDER)
CATALOG_EMBED_MODEL=nomic-embed-text

# ==========================================
# Deployment Notes:
#
# 1. For production, use database settings (POST /api/settings/{key})
#    instead of environment variables
#
# 2. All API keys and passwords should be secrets in your deployment:
#    - Docker: use --env-file or secrets
#    - Kubernetes: use ConfigMaps and Secrets
#    - Cloud: use managed secret stores
#
# 3. Settings Priority (highest to lowest):
#    a) Database (set via /api/settings/{key} endpoint)
#    b) Environment variables (from this file)
#    c) Hardcoded defaults in config/settings.py
#
# 4. To use different LLM providers at runtime:
#    POST /api/settings/llm_provider with {"value": "openai"}
#    Then POST /api/settings/openai_api_key with {"value": "sk-..."}
#    Then POST /api/llm/test to verify connection
# ==========================================
