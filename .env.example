# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# LLM — Ollama locally, or Cloudera AI Inference in prod
CLOUDERA_AI_URL=http://localhost:11434/v1
CLOUDERA_AI_MODEL=llama3.2:latest
CLOUDERA_AI_KEY=ollama

# Iceberg catalog
# Options: hadoop (local path) | rest (Cloudera REST via Knox) | hive (HMS)
ICEBERG_CATALOG_TYPE=hadoop
ICEBERG_CATALOG_URI=
ICEBERG_WAREHOUSE=/path/to/iceberg-warehouse
# Knox JWT for Cloudera REST catalog auth (run knoxshare.py to obtain)
KNOX_JWT=
# Knox automatic token refresh — set these to avoid manual JWT rotation during demos
KNOX_LOGIN_URL=
KNOX_USERNAME=
KNOX_PASSWORD=
# Refresh the token when fewer than this many seconds remain (default 120 = 2 min buffer)
KNOX_TOKEN_REFRESH_BUFFER_SECS=120

# Apache Ozone (S3-compatible endpoint)
OZONE_ENDPOINT=http://localhost:9878
OZONE_ACCESS_KEY=
OZONE_SECRET_KEY=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Options: PLAINTEXT | SASL_PLAINTEXT | SASL_SSL
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# Options: (empty) | PLAIN | SCRAM-SHA-256 | GSSAPI
KAFKA_SASL_MECHANISM=
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SSL_CA_LOCATION=

# HDFS WebHDFS
HDFS_WEBHDFS_URL=http://localhost:9870
HDFS_USER=hdfs

# Flink REST API
FLINK_REST_URL=http://localhost:8081

# Schema Registry (Confluent / Cloudera)
SCHEMA_REGISTRY_URL=
# Options: cloudera (Cloudera/HWX SR, aggregated API) | confluent (Confluent SR, subjects API)
SCHEMA_REGISTRY_TYPE=cloudera
# Options: NONE | KERBEROS | BASIC
SCHEMA_REGISTRY_AUTH_TYPE=NONE
# Kerberos: path to keytab file and principal (e.g. kafka/schema-registry.host@REALM)
SCHEMA_REGISTRY_KEYTAB=
SCHEMA_REGISTRY_PRINCIPAL=
# BASIC auth (when not Kerberized)
SCHEMA_REGISTRY_USER=
SCHEMA_REGISTRY_PASSWORD=

# Iceberg schema cache
ICEBERG_CACHE_TTL_SECONDS=300
